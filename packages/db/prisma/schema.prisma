generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  scans     Scan[]
}

model Scan {
  id         String   @id @default(cuid())
  userId     String?
  cubeState  String
  solution   String
  moveCount  Int
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}